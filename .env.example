# TinyWebhook — runtime configuration
#
# Copy this file to `.env` and edit, or set these variables directly in your
# runtime (Docker `-e VAR=value`, Dokploy env panel, systemd EnvironmentFile,
# etc.). Anything left unset uses the default shown after `=`.
#
# Misconfiguration is loud: an unparseable or out-of-bounds value throws at
# startup so a typo fails fast instead of running with the wrong limit.

# ── Network ─────────────────────────────────────────────────────────────────

# Bind port for the Node server (read by SvelteKit's adapter-node).
PORT=3000

# Bind interface. 0.0.0.0 listens on all interfaces; use 127.0.0.1 for
# loopback-only behind a reverse proxy on the same host.
HOST=0.0.0.0

# Origin used server-side when generating the absolute webhookUrl and
# dashboardUrl returned by POST /api/inboxes. When unset, the server derives
# the origin from the incoming request (works fine behind a reverse proxy that
# forwards Host correctly). When set, this overrides — operator's word is
# final. Must be an origin only (scheme + host + optional port), no path.
#
# PROD: PUBLIC_BASE_URL=https://webhook.dexli.dev
PUBLIC_BASE_URL=

# ── Storage / per-inbox limits ──────────────────────────────────────────────

# Inbox lifetime in hours. After this, the inbox + its requests are swept.
INBOX_TTL_HOURS=24

# Max accepted request body size in bytes (per captured webhook request).
# Requests larger than this get HTTP 413 and are not recorded.
MAX_BODY_BYTES=262144

# Max stored requests per inbox. Oldest requests are evicted past this.
MAX_REQUESTS_PER_INBOX=50

# ── Rate limits ─────────────────────────────────────────────────────────────

# Max inbox creations allowed per source IP per rolling hour. Caller gets
# HTTP 429 above this.
MAX_INBOXES_PER_IP_PER_HOUR=20

# ── SSE (live updates stream) ───────────────────────────────────────────────

# Max concurrent SSE streams per inbox. The (cap+1)-th subscriber on a hot
# inbox receives a terminal `event: error` frame and the stream closes;
# existing streams are unaffected.
SSE_MAX_PER_INBOX=8

# Max concurrent SSE streams across all inboxes (global flooding cap).
SSE_MAX_GLOBAL=256
